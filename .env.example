# ==============================================================
# Stardock Podium Environment Configuration
# Copy this file to .env and fill in your values.
# ==============================================================

# ---- Required API keys -----------------------------------------
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
MEM0_API_KEY=m0-...

# ---- Optional: ElevenLabs (only if using the legacy engine) ----
# ELEVENLABS_API_KEY=...

# ==============================================================
# Cloud / custom paths (for RunPod, Docker, etc.)
# Leave blank for local development — the repo works out of the
# box with relative paths under the project root.
# ==============================================================

# Path to Kokoro weights. On RunPod, point at persistent storage
# so the ~330 MB download survives pod shutdowns. If unset, the
# Kokoro KPipeline auto-downloads from HuggingFace on first use.
# KOKORO_MODEL_PATH=/workspace/models/kokoro-tts-base-ft.pt

# Optional: persist the HuggingFace cache to /workspace.
# HF_HOME=/workspace/models/hf_cache

# Persistent data directories. On RunPod, mount your Network
# Volume at /workspace and point these under it so your books,
# voices, episodes, and audio survive pod restarts.
# STARDOCK_BOOKS_DIR=/workspace/Stardock_Podium_v4/books
# STARDOCK_VOICES_DIR=/workspace/Stardock_Podium_v4/voices
# STARDOCK_EPISODES_DIR=/workspace/Stardock_Podium_v4/episodes
# STARDOCK_AUDIO_DIR=/workspace/Stardock_Podium_v4/audio
# STARDOCK_DATA_DIR=/workspace/Stardock_Podium_v4/data
# STARDOCK_ANALYSIS_DIR=/workspace/Stardock_Podium_v4/analysis

# Ephemeral (pod-local) temp dir — safe to leave as default.
# STARDOCK_TEMP_DIR=/workspace/Stardock_Podium_v4/temp
