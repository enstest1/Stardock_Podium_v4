# Environment variables
.env
# Allow example environment file to be versioned
# Python
.venv-xtts/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
logs/

# Generated / local runtime data (keep out of git)
# NOTE: These directories can be re-created by running the CLI.
books/
analysis/
episodes/
output/
temp/

# Audio files
*.wav
*.mp3
*.ogg
*.flac
*.m4a
*.aac
*.mp4
audio/
episodes/*/audio/

# Images / media exports
*.jpeg
*.jpg
*.png
*.webp
# Allow committed documentation assets (banner, diagrams, etc.)
!Docs/assets/**

# Bundled theme for intro/outro (see audio_pipeline assets/music discovery)
!assets/music/*.wav
!assets/music/*.mp3

# Casting / XTTS reference samples (tracked intentionally)
!voices/samples/**/*.wav
!voices/samples/**/*.mp3

# Temporary files
*.tmp

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project specific
.cursor/
.claude/

# Repomix
repomix-output.xml 